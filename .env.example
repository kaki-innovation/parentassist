# ============================================================
# ParentAssist — Environment Variables
# Copy this file to .env and fill in real values.
# NEVER commit .env to source control.
# ============================================================

# ─── apps/api ───────────────────────────────────────────────

# Anthropic — AI backbone
ANTHROPIC_API_KEY=

# Supabase — database + auth (service role, backend only)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Pinecone — RAG vector store
PINECONE_API_KEY=
PINECONE_INDEX=parentassist-prod

# Redis — AI response cache (Upstash)
REDIS_URL=

# LangSmith — AI call tracing
LANGSMITH_API_KEY=

# Sentry — backend error monitoring
SENTRY_DSN=

# ─── apps/mobile ────────────────────────────────────────────

# Backend API URL (localhost in dev, Railway URL in prod)
EXPO_PUBLIC_API_URL=

# Supabase — public keys only (anon key, safe to expose)
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# PostHog — product analytics
EXPO_PUBLIC_POSTHOG_KEY=

# Image provider: unsplash | pexels | supabase | ai
EXPO_PUBLIC_IMAGE_PROVIDER=unsplash
EXPO_PUBLIC_UNSPLASH_ACCESS_KEY=

# Push notifications (set false during Expo Go development)
PUSH_NOTIFICATIONS_ENABLED=false

# ─── apps/web ───────────────────────────────────────────────

# Next.js public URL (set in production)
NEXT_PUBLIC_APP_URL=

# Same Supabase anon key as mobile (public)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
